{
  "name": "diary-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "rm -rf .next && next dev -p 5000",
    "dev:fast": "next dev -p 5000",
    "dev:clean": "rm -rf .next && next dev -p 5000",
    "build": "next build",
    "start": "next start -p 5000",
    "export": "echo \"Static export is enabled in next.config.mjs via output: export.\"",
    "mobile:bootstrap": "npm i @capacitor/cli @capacitor/core @capacitor/ios @capacitor/splash-screen && npx cap init \"Daily Flow Diary\" com.dailyflow.diary --web-dir=out --npm-client=npm",
    "mobile:init": "if [ ! -f capacitor.config.ts ] && [ ! -f capacitor.config.json ]; then npx cap init \"Daily Flow Diary\" com.dailyflow.diary --web-dir=out --npm-client=npm; else echo \"Capacitor config exists. Skip init.\"; fi",
    "mobile:add-ios": "npx cap add ios",
    "mobile:sync-ios": "npx cap sync ios",
    "mobile:open-ios": "npx cap open ios",
    "mobile:build": "npm run build && npm run mobile:sync-ios",
    "lint": "next lint"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/push-notifications": "^6.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capgo/capacitor-purchases": "^10.0.0",
    "@supabase/supabase-js": "^2.53.0",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.511.0",
    "motion": "^12.35.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "glob": "^10.5.0"
  }
}
